# --- App
NODE_ENV=development
PORT=3001
API_BASE_PATH=/api
CORS_ORIGIN=http://localhost:3000
COOKIE_NAME=crwla_token

# --- Database (NEW DATABASE_URL — separate from legacy scrape-yard DB)
DATABASE_URL=postgresql://crwla:crwla@localhost:5432/crwla?schema=public

# --- Auth
JWT_SECRET=change-me-in-production
SESSION_DAYS=14

# --- Initial admin (created on first boot if no users exist)
ADMIN_EMAIL=admin@crwla.io
ADMIN_PASSWORD=admin
ADMIN_NAME=Admin

# --- Redis / BullMQ (required for queues)
REDIS_URL=redis://localhost:6379

# --- Elasticsearch (optional — falls back to Postgres FTS if unset)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=crwla_results

# --- Scraper
USER_AGENT=CRWLA/1.0 (+https://github.com/crwla)
DEFAULT_LOCALE=en-US
DEFAULT_REGION=US

# --- Anthropic (optional — enables LLM filter prompts; otherwise heuristic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Billing (Polar.sh) -------------------------------------------------------
# Public-facing web base URL — used to build Polar checkout success_url etc.
WEB_BASE_URL=http://localhost:3000

# Required to enable billing. Without these, /api/billing/plans + /me still
# work but checkout/portal/webhook 400 with "billing not configured".
# `sandbox` for testing, `production` for live — keep the value bare
# (no inline comments; .env parsers may include trailing text in the value).
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_WEBHOOK_SECRET=

# Plan and add-on Polar products are managed from /admin/billing — the
# server creates them automatically on first save and stores the returned
# ids on the Plan rows. No product/price env vars needed.

# --- Mailtrap (transactional mail) ------------------------------------------
# Used by /api/contact to notify support of new public form submissions.
# Defaults below target the Mailtrap sandbox; switch host/port + creds for
# production (`send.smtp.mailtrap.io` on port 587 with your API token).
# Missing credentials = submissions still persist; the email step is skipped.
MAIL_FROM="CRWLA <hello@crwla.com>"
MAIL_SUPPORT_TO=support@crwla.com
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASSWORD=

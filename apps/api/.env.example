# --- App
NODE_ENV=development
PORT=3001
API_BASE_PATH=/api
CORS_ORIGIN=http://localhost:3000
COOKIE_NAME=crwla_token

# --- Database (NEW DATABASE_URL — separate from legacy scrape-yard DB)
DATABASE_URL=postgresql://crwla:crwla@localhost:5432/crwla?schema=public

# --- Auth
JWT_SECRET=change-me-in-production
SESSION_DAYS=14

# --- Initial admin (created on first boot if no users exist)
ADMIN_EMAIL=admin@crwla.io
ADMIN_PASSWORD=admin
ADMIN_NAME=Admin

# --- Redis / BullMQ (required for queues)
REDIS_URL=redis://localhost:6379

# --- Elasticsearch (optional — falls back to Postgres FTS if unset)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=crwla_results

# --- Scraper
USER_AGENT=CRWLA/1.0 (+https://github.com/crwla)
DEFAULT_LOCALE=en-US
DEFAULT_REGION=US

# --- Anthropic (optional — enables LLM filter prompts; otherwise heuristic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# web-page-extractor-llm — env config.
#
# You DO NOT need this file for local docker-compose dev — the compose
# `app` service has sane defaults (DATABASE_URL → bundled postgres,
# OLLAMA_HOST → bundled ollama). Copy this file to `.env` only when
# you need to override something (eg. set API_TOKEN, point at a
# different DB, swap the model).
#
# For production (Railway), the env vars are set on the service in
# the dashboard — this file is just documentation of what's available.

# ── Server ────────────────────────────────────────────────────
# Railway injects PORT automatically; only override locally.
PORT=8000

# ── Model selection ───────────────────────────────────────────
# Public tag for cold-start dev; switch to your fine-tuned tag
# (e.g. web-page-extractor-llm:latest) once you've built a Modelfile.
MODEL_NAME=qwen2.5:7b-instruct-q4_K_M

# Path to a Modelfile inside the container. When present, start.sh
# runs `ollama create $MODEL_NAME -f $MODELFILE_PATH` instead of
# `ollama pull`. Set this after you've baked your fine-tuned GGUF
# into the image (or mounted it via a Railway volume).
# MODELFILE_PATH=/app/scripts/Modelfile

# ── Ollama daemon ─────────────────────────────────────────────
# Compose default points the app at the `ollama` service. Override
# only when running uvicorn directly (Option B in README) and Ollama
# is on the host — then use 127.0.0.1:11434.
# OLLAMA_HOST=ollama:11434

# ── Inference tuning ──────────────────────────────────────────
# Token cap for the page text we send. 32K is comfortable for
# Qwen at Q4_K_M on 16 GB; drop to 16K on tighter plans.
MAX_PAGE_TOKENS=24000
# Lower temperature for more deterministic JSON.
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9
# Max tokens to generate. Most schemas fit in <1K.
LLM_MAX_TOKENS=2048

# ── Postgres + pgvector ───────────────────────────────────────
# Local compose default (used when this var is unset):
#   postgres://wpe:wpe@postgres:5432/wpe
# Railway exposes DATABASE_URL automatically when you attach the
# Postgres plugin — leave this commented out in production.
# DATABASE_URL=postgres://wpe:wpe@postgres:5432/wpe

# ── Few-shot retrieval ────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
FEW_SHOT_K=2
# Minimum cosine similarity for an example to be included as few-shot.
FEW_SHOT_MIN_SIM=0.55

# ── Fetcher ───────────────────────────────────────────────────
USER_AGENT=Mozilla/5.0 (compatible; web-page-extractor-llm/1.0)
FETCH_TIMEOUT_S=15
# When true, the fetcher always uses Playwright. When false (default),
# it falls back to Playwright only after the static HTTP fetch fails
# to produce extractable text.
ALWAYS_RENDER_JS=false

# ── Validation / retry ────────────────────────────────────────
# How many corrective re-prompts after a JSON-schema failure.
MAX_VALIDATION_RETRIES=2

# ── Auth (optional) ───────────────────────────────────────────
# Set to require Bearer auth on /extract and /v1/chat/completions.
# API_TOKEN=

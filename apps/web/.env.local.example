# Server-side base URL — used by server components when calling the API
# directly (cookies are forwarded). Defaults to localhost in dev.
API_URL=http://localhost:3001

# Client-side base URL — defaults to "/api" so requests hit Next's
# rewrite (configured in next.config.mjs) which proxies to API_URL.
NEXT_PUBLIC_API_URL=/api

# Client-side reCAPTCHA v3 site key (pairs with RECAPTCHA_SECRET_KEY on
# the API). Leave empty to disable the captcha in dev.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
